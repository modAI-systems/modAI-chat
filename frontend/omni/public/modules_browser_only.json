{
  "version": "1.0.0",
  "modules": [
    {
      "id": "app-root",
      "type": "AppRoot",
      "path": "@/modules/app-layout/AppRoot",
      "dependencies": {
        "module:layout": "app-layout",
        "module:appRouter": "app-router"
      }
    },
    {
      "id": "app-router",
      "type": "AppRouter",
      "path": "@/modules/app-layout/AppRouter/create",
      "dependencies": {
        "module:routes": ["chat-route", "providers-route"],
        "module:fallbackRoute": "chat-fallback-route"
      }
    },
    {
      "id": "fetch-service",
      "type": "FetchService",
      "path": "@/modules/fetch-service/pureFetchService/create",
      "dependencies": {}
    },
    {
      "id": "app-layout",
      "type": "AppLayout",
      "path": "@/modules/app-layout/AppLayout",
      "dependencies": {
        "module:appRouter": "app-router",
        "module:chatbots": ["chatbot"],
        "module:providerManagement": ["llm-provider-management"]
      }
    },
    {
      "id": "llm-provider-service",
      "type": "LLMProviderService",
      "path": "@/modules/llm-provider-service/localStorageLLMProviderService/create",
      "dependencies": {}
    },
    {
      "id": "chat-service",
      "type": "ChatService",
      "path": "@/modules/chat-service/openai/create",
      "dependencies": {
        "module:fetchService": "fetch-service"
      }
    },
    {
      "id": "chatbot",
      "type": "ChatbotComponent",
      "path": "@/modules/chatbot/ChatbotComponent",
      "dependencies": {
        "module:chatService": "chat-service",
        "module:llmProviderService": "llm-provider-service"
      }
    },
    {
      "id": "chat-route",
      "type": "Route",
      "path": "@/modules/chatbot/chatRouteDefinition/create",
      "dependencies": {
        "module:chatbots": ["chatbot"]
      }
    },
    {
      "id": "chat-fallback-route",
      "type": "FallbackRoute",
      "path": "@/modules/chatbot/chatFallbackRouteDefinition/create",
      "dependencies": {}
    },
    {
      "id": "llm-provider-management",
      "type": "LLMProviderManagementComponent",
      "path": "@/modules/llm-provider-management/LLMProviderManagementComponent",
      "dependencies": {
        "module:llmProviderService": "llm-provider-service"
      }
    },
    {
      "id": "providers-route",
      "type": "Route",
      "path": "@/modules/llm-provider-management/providersRouteDefinition/create",
      "dependencies": {
        "module:providerManagement": ["llm-provider-management"]
      }
    }
  ]
}
