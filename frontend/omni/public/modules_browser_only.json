{
  "version": "1.0.0",
  "modules": [
    {
      "id": "app-root",
      "type": "AppRoot",
      "path": "@/core/main/AppRoot",
      "dependencies": {
        "module:mainApp": "routing-main"
      }
    },
    {
      "id": "routing-main",
      "type": "MainApp",
      "path": "@/modules/router/AppRouter",
      "dependencies": {
        "module:routes": ["chat-route", "providers-route", "tools-route", "chat-fallback-route", "sidebar-layout-route"]
      }
    },
    {
      "id": "sidebar-layout",
      "type": "MainApp",
      "path": "@/modules/main-app-sidebar-based/MainApp",
      "dependencies": {
        "module:sidebarTopItems": ["chat-navigation-item", "providers-navigation-item", "tools-navigation-item"]
      }
    },
    {
      "id": "sidebar-layout-route",
      "type": "Routes",
      "path": "@/modules/main-app-sidebar-based/layoutRouteDefinition/create",
      "dependencies": {}
    },
    {
      "id": "fetch-service",
      "type": "FetchService",
      "path": "@/modules/fetch-service/pureFetchService/create",
      "dependencies": {}
    },
    {
      "id": "llm-provider-service",
      "type": "LLMProviderService",
      "path": "@/modules/llm-provider-service/localStorageLLMProviderService/create",
      "dependencies": {}
    },
    {
      "id": "chat-service",
      "type": "ChatService",
      "path": "@/modules/chat-service/openai/create",
      "dependencies": {
        "module:fetchService": "fetch-service"
      }
    },
    {
      "id": "chat",
      "type": "ChatComponent",
      "path": "@/modules/chat/ChatComponent",
      "dependencies": {
        "module:chatService": "chat-service",
        "module:llmProviderService": "llm-provider-service",
        "module:toolsService": "tools-service"
      }
    },
    {
      "id": "chat-navigation-item",
      "type": "SidebarTopItem",
      "path": "@/modules/chat/chatNavigationItem",
      "dependencies": {}
    },
    {
      "id": "chat-route",
      "type": "Route",
      "path": "@/modules/chat/chatRouteDefinition/create",
      "dependencies": {
        "module:chat": ["chat"]
      }
    },
    {
      "id": "chat-fallback-route",
      "type": "FallbackRoute",
      "path": "@/modules/chat/chatFallbackRouteDefinition/create",
      "dependencies": {
        "module:chat": ["chat"]
      }
    },
    {
      "id": "llm-provider-management",
      "type": "LLMProviderManagementComponent",
      "path": "@/modules/llm-provider-management/LLMProviderManagementComponent",
      "dependencies": {
        "module:llmProviderService": "llm-provider-service"
      }
    },
    {
      "id": "tools-service",
      "type": "ToolsService",
      "path": "@/modules/tools-service/emptyToolsService/create",
      "dependencies": {}
    },
    {
      "id": "tools-management",
      "type": "ToolsManagementComponent",
      "path": "@/modules/tools-management/ToolsManagementComponent",
      "dependencies": {
        "module:toolsService": "tools-service"
      }
    },
    {
      "id": "providers-navigation-item",
      "type": "SidebarTopItem",
      "path": "@/modules/llm-provider-management/providersNavigationItem",
      "dependencies": {}
    },
    {
      "id": "tools-navigation-item",
      "type": "SidebarTopItem",
      "path": "@/modules/tools-management/toolsNavigationItem",
      "dependencies": {}
    },
    {
      "id": "providers-route",
      "type": "Route",
      "path": "@/modules/llm-provider-management/providersRouteDefinition/create",
      "dependencies": {
        "module:providerManagement": ["llm-provider-management"]
      }
    },
    {
      "id": "tools-route",
      "type": "Route",
      "path": "@/modules/tools-management/toolsRouteDefinition/create",
      "dependencies": {
        "module:toolsManagement": ["tools-management"]
      }
    }
  ]
}
