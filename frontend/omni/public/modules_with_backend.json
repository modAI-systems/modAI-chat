{
  "version": "1.0.0",
  "modules": [
    {
      "id": "app-root",
      "type": "AppRoot",
      "path": "@/core/main/AppRoot",
      "dependencies": {
        "module:mainApp": "main-app-session-gated"
      }
    },
    {
      "id": "main-app-session-gated",
      "type": "AppLayout",
      "path": "@/modules/session-service/SessionGatedAppLayout",
      "dependencies": {
        "module:sessionService": "session-service",
        "module:noSessionAction": "no-session-action",
        "module:wrappedApp": "routing-main"
      }
    },
    {
      "id": "routing-main",
      "type": "MainApp",
      "path": "@/modules/router/AppRouter",
      "dependencies": {
        "module:routes": ["chat-route", "providers-route", "chat-fallback-route", "sidebar-layout-route"]
      }
    },
    {
      "id": "sidebar-layout",
      "type": "MainApp",
      "path": "@/modules/main-app-sidebar-based/MainApp",
      "dependencies": {
        "module:sidebarTopItems": ["chat-navigation-item", "providers-navigation-item"]
      }
    },
    {
      "id": "sidebar-layout-route",
      "type": "Routes",
      "path": "@/modules/main-app-sidebar-based/layoutRouteDefinition/create",
      "dependencies": {}
    },
    {
      "id": "plain-fetch-service",
      "type": "FetchService",
      "path": "@/modules/fetch-service/pureFetchService/create",
      "dependencies": {}
    },
    {
      "id": "fetch-service",
      "type": "FetchService",
      "path": "@/modules/fetch-service/sessionFetchService/create",
      "dependencies": {
        "module:sessionService": "session-service",
        "module:noSessionAction": "no-session-action"
      }
    },
    {
      "id": "session-service",
      "type": "SessionService",
      "path": "@/modules/session-service/sessionServiceImpl/create",
      "dependencies": {
        "module:fetchService": "plain-fetch-service"
      }
    },
    {
      "id": "no-session-action",
      "type": "NoSessionAction",
      "path": "@/modules/session-service/loginRedirectAction/create",
      "dependencies": {}
    },
    {
      "id": "llm-provider-service",
      "type": "LLMProviderService",
      "path": "@/modules/llm-provider-service/modaiBackendLLMProviderService/create",
      "dependencies": {
        "module:fetchService": "fetch-service"
      }
    },
    {
      "id": "chat-service",
      "type": "ChatService",
      "path": "@/modules/chat-service/openai/create",
      "dependencies": {
        "module:fetchService": "fetch-service"
      }
    },
    {
      "id": "chat",
      "type": "ChatComponent",
      "path": "@/modules/chat/ChatComponent",
      "dependencies": {
        "module:chatService": "chat-service",
        "module:llmProviderService": "llm-provider-service",
        "module:toolsService": "tools-service"
      }
    },
    {
      "id": "chat-navigation-item",
      "type": "SidebarTopItem",
      "path": "@/modules/chat/chatNavigationItem",
      "dependencies": {}
    },
    {
      "id": "chat-route",
      "type": "Route",
      "path": "@/modules/chat/chatRouteDefinition/create",
      "dependencies": {
        "module:chat": ["chat"]
      }
    },
    {
      "id": "chat-fallback-route",
      "type": "FallbackRoute",
      "path": "@/modules/chat/chatFallbackRouteDefinition/create",
      "dependencies": {
        "module:chat": ["chat"]
      }
    },
    {
      "id": "llm-provider-management",
      "type": "LLMProviderManagementComponent",
      "path": "@/modules/llm-provider-management/LLMProviderManagementComponent",
      "dependencies": {
        "module:llmProviderService": "llm-provider-service"
      }
    },
    {
      "id": "tools-service",
      "type": "ToolsService",
      "path": "@/modules/tools-service/modaiBackendToolsService/create",
      "dependencies": {
        "module:fetchService": "fetch-service"
      }
    },
    {
      "id": "providers-navigation-item",
      "type": "SidebarTopItem",
      "path": "@/modules/llm-provider-management/providersNavigationItem",
      "dependencies": {}
    },
    {
      "id": "providers-route",
      "type": "Route",
      "path": "@/modules/llm-provider-management/providersRouteDefinition/create",
      "dependencies": {
        "module:providerManagement": ["llm-provider-management"]
      }
    }
  ]
}
