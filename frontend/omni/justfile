# ModAI Frontend

default:
    @just --list

# Install dependencies
install:
    pnpm install

# Start the development server
start:
    pnpm dev

# Build for production
build:
    pnpm build

# Run tests
test:
    pnpm test

# Check code style and linting
check:
    pnpm check

# Fix code style and linting issues
format:
    pnpm check:write
