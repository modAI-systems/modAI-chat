CONFIG_PATH=./src/modai/default_config.yaml

# Some tests run against the OpenAI API, so we need to provide an API key. If not provided, those tests will be skipped.
# UNIT_TEST_OPENAI_API_KEY=sk-...

# NanoIDP settings for local development (see resources/compose-files/compose-nanoidp.yaml)
OIDC_ISSUER=http://localhost:9000
OIDC_CLIENT_ID=test-client
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/callback
OIDC_POST_LOGIN_URI=http://localhost:5173/
OIDC_POST_LOGOUT_URI=http://localhost:5173/
SESSION_SECRET=dev-session-secret-32-chars!!!!!
